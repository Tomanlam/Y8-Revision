rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // DEFAULT DENY
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email == "tomanlam@gmail.com";
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ===============================================================
    // Validation Helpers
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'email', 'progress', 'lastSeen']) &&
             data.userId == request.auth.uid;
    }

    function isValidSubmission(data) {
      // Basic structure validation
      return data.keys().hasAll(['id', 'taskId', 'userId', 'completedAt', 'studentName', 'responses']) &&
             data.userId == request.auth.uid &&
             data.id == data.taskId + "_" + data.userId;
    }

    function isValidStickyNote(data) {
      return data.userId == request.auth.uid &&
             data.content is string && data.content.size() <= 3000 &&
             data.color is string;
    }

    function isValidMessage(data) {
      return data.senderId == request.auth.uid &&
             data.senderName is string &&
             data.receiverIds is list &&
             data.participants is list &&
             data.participants.hasAll([data.senderId]) &&
             data.text is string && data.text.size() <= 5000 &&
             data.timestamp is string &&
             data.type in ['individual', 'announcement'] &&
             data.isRead is map;
    }

    // ===============================================================
    // Match Blocks
    // ===============================================================

    match /messages/{messageId} {
      allow get: if isSignedIn() && (
        isAdmin() || 
        request.auth.uid in resource.data.participants ||
        resource.data.type == 'announcement'
      );
      allow list: if isSignedIn() && (
        isAdmin() || 
        request.auth.uid in resource.data.participants ||
        resource.data.type == 'announcement'
      );
      
      // Admin can create any message
      // Students/Parents can create individual messages to send (Reply)
      allow create: if isSignedIn() && isValidMessage(request.resource.data) && (
        isAdmin() || 
        (request.resource.data.type == 'individual')
      );

      // Only allow updating isRead for the current user
      allow update: if isSignedIn() && (
        isAdmin() || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']) &&
          request.resource.data.isRead[request.auth.uid] == true &&
          request.resource.data.senderId == resource.data.senderId &&
          request.resource.data.receiverIds == resource.data.receiverIds
        )
      );

      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /submissions/{submissionId} {
      // Students can read their own work
      // Admin can read all work
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      // Creating: Students can only create for themselves. 
      // Enforce the once-only rule by checking if document already exists
      allow create: if isSignedIn() && 
                      isValidSubmission(request.resource.data) && 
                      !exists(/databases/$(database)/documents/submissions/$(submissionId));
      
      // Updating: 
      // 1. Students CANNOT update their submission (submit once)
      // 2. Admin CAN update to add grading/feedback
      allow update: if isAdmin() && 
                      request.resource.data.userId == resource.data.userId &&
                      request.resource.data.taskId == resource.data.taskId;

      // Deleting: Only Admin
      allow delete: if isAdmin();
    }

    match /challengeRecords/{recordId} {
      allow create: if isSignedIn();
      allow read, delete: if isAdmin();
    }

    match /markschemes/{taskId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /processedRubrics/{taskId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /interactiveNotes/{unitId} {
      allow get: if true;
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    match /stickyNotes/{noteId} {
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidStickyNote(request.resource.data);
    }
  }
}
