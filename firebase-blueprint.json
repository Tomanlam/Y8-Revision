{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a student or admin user and their persistent progress.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "progress": { 
          "type": "object",
          "description": "User's progress across units (SessionStats structure)."
        },
        "lastSeen": { "type": "string", "format": "date-time" },
        "isAdmin": { "type": "boolean" }
      },
      "required": ["userId", "email", "progress", "lastSeen"]
    },
    "Task": {
      "title": "Task",
      "description": "An assigned task for students to complete.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "units": { "type": "array", "items": { "type": "integer" } },
        "dueDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "archived"] }
      },
      "required": ["id", "title", "status"]
    },
    "TaskSubmission": {
      "title": "Task Submission",
      "description": "A student's completion record for a specific task.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique key: taskId_userId" },
        "taskId": { "type": "string" },
        "userId": { "type": "string" },
        "studentName": { "type": "string" },
        "completedAt": { "type": "string", "format": "date-time" },
        "responses": { "type": "object" },
        "feedback": { "type": "object", "description": "Admin grading feedback and scores" },
        "results": { 
          "type": "object",
          "properties": {
            "score": { "type": "number" },
            "total": { "type": "number" }
          }
        }
      },
      "required": ["id", "taskId", "userId", "completedAt", "responses"]
    },
    "ChallengeRecord": {
      "title": "Challenge Record",
      "description": "A record of a student's performance in a quiz challenge or Easter assignment.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentName": { "type": "string" },
        "score": { "type": "integer" },
        "totalQuestions": { "type": "integer" },
        "selectedUnits": { "type": "array", "items": { "type": "integer" } },
        "responses": { "type": "array" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "studentName", "score", "totalQuestions", "selectedUnits", "responses", "timestamp"]
    },
    "Markscheme": {
      "title": "Markscheme",
      "description": "Administrator-editable markschemes for assignments.",
      "type": "object",
      "properties": {
        "content": { "type": "string" }
      },
      "required": ["content"]
    },
    "ProcessedRubric": {
      "title": "Processed Rubric",
      "description": "Extracted and mapped rubrics for a specific task.",
      "type": "object",
      "properties": {
        "taskId": { "type": "string" },
        "rubrics": { "type": "object", "description": "Map of questionId to JSON rubric string" },
        "meta": { "type": "object", "description": "Map of questionId to {type, marks}" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["taskId", "rubrics", "meta", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A communication message between admin and student/parent.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "receiverIds": { "type": "array", "items": { "type": "string" } },
        "participants": { "type": "array", "items": { "type": "string" } },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isRead": { "type": "object", "description": "Map of userId to boolean" },
        "type": { "type": "string", "enum": ["individual", "announcement"] }
      },
      "required": ["senderId", "senderName", "receiverIds", "text", "timestamp", "isRead", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and progress."
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Assigned tasks."
    },
    "/submissions/{submissionId}": {
      "schema": "TaskSubmission",
      "description": "Student task completions. submissionId is $(taskId)_$(userId)"
    },
    "/challengeRecords/{recordId}": {
      "schema": "ChallengeRecord",
      "description": "Collection of all quiz records."
    },
    "/markschemes/{taskId}": {
      "schema": "Markscheme",
      "description": "Editable markschemes by task ID."
    },
    "/processedRubrics/{taskId}": {
      "schema": "ProcessedRubric",
      "description": "Cached rubrics for automated grading."
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "System communications and messages."
    }
  }
}
